{
  "name": "crm-sign-medios-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:integration": "node --import tsx --test src/infrastructure/database/**/*.integration.test.ts",
    "test:all": "npm run test && npm run test:integration"
  },

  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "16.4.1",
    "express": "4.21.2",
    "helmet": "4.1.1",
    "pg": "8.2.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.2",
    "@types/express": "5.0.1",
    "@types/node": "22.10.1",
    "@types/pg": "8.11.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "4.19.0",
    "typescript": "5.7.3"
  }
}
