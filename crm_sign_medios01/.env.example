# Database Configuration
# For local development use: postgres://user:password@localhost:5432/crm_sign_medios
# For Docker use: postgresql://user:password@postgres:5432/crm_sign_medios
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=crm_sign_medios
POSTGRES_PORT=5432
DATABASE_URL=postgres://user:password@localhost:5432/crm_sign_medios

# Backend Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=dev-secret

# Frontend API Configuration
VITE_API_BASE=http://localhost:3000/api
VITE_API_PROXY_TARGET=http://localhost:3000

# WhatsApp Configuration
WHATSAPP_TOKEN=your-whatsapp-token-here
WHATSAPP_API_URL=https://graph.facebook.com/v25.0/YOUR_PHONE_NUMBER_ID/messages

# Meta/Facebook Configuration
META_VERIFY_TOKEN=your-meta-verify-token
META_APP_SECRET=your-meta-app-secret
META_APP_ID=your-meta-app-id
META_GRAPH_VERSION=v16.0

# TLS Configuration (optional)
# DEV_TLS=false
# DEV_TLS_CERT_PATH=
# DEV_TLS_KEY_PATH=
